DISCORD_TOKEN=your_discord_bot_token
OPENROUTER_API_KEY=your_openrouter_api_key
BRAVE_API_KEY=your_brave_search_api_key
LOG_LEVEL=info
# Docker-compose service name — only resolves inside the compose network.
# For host-side usage (e.g. tests), use make test which overrides this automatically.
QDRANT_URL=http://qdrant:6333
# Optional: ElevenLabs API key for voice message generation
ELEVENLABS_API_KEY=your_elevenlabs_api_key
DATA_DIR=data
MODEL_CACHE_DIR=model-cache
DASHBOARD_PASSWORD=your_dashboard_password
# Comma/whitespace-separated CIDRs that can access the dashboard without a password.
DASHBOARD_PASSWORDLESS_CIDRS=10.16.0.0/16
# Comma/whitespace-separated proxy CIDRs whose forwarded client IP headers are trusted.
# Add your Docker bridge gateway here when proxying through a host-published port.
DASHBOARD_TRUSTED_PROXY_CIDRS=127.0.0.1/32
