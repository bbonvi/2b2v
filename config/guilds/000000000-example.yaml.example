# Per-guild configuration — config/guilds/{guildId}-{slug}.yaml
# All fields are optional. Missing values inherit from config/config.yaml defaults.
# Note: uiLang and vpn settings are global-only (set in config/config.yaml).

# Trigger settings — when should the bot respond?
triggers:
  mention: true            # Respond when @mentioned
  keywords: [2b, yorha]   # Keywords that trigger a response
  randomChance: 0.02       # 0–1 probability of responding to any message
  keywordDebounceMs: 2500  # Wait after a keyword trigger before replying
  typingIdleMs: 10000      # Treat typingStart from the triggering user as active for this long
  typingMaxWaitMs: 15000   # Hard cap for typing-aware keyword waits

# Trigger-specific instructions (overrides global defaults per-key).
# triggerInstructions:
#   random: "In this server, unprompted replies should be playful."

# LLM model override (OpenRouter model ID). Omit to use global default.
model: moonshotai/kimi-k2.5

# Additional model parameters passed to OpenRouter (merges with global defaults)
# modelParams:
#   temperature: 0.8
#   reasoning:
#     effort: "high"  # Override global reasoning level for this guild

# Thinking/reasoning level for the model (optional)
# When omitted, inherits from global config (which may also be omitted, meaning no thinking).
# Valid values: "minimal" | "low" | "medium" | "high" | "xhigh"
# thinkingLevel: medium

# Guild timezone — used for all agent-facing timestamps, scheduling, and date stamps.
# One-off schedules always use this timezone. Cron schedules default to it unless overridden.
timezone: UTC

# Context window trimming thresholds
trim:
  trimTrigger: 200
  trimTarget: 150
  windowSize: 20
  messageCharLimit: 200
  replyQuoteChars: 50

# Discord user IDs with admin access to bot commands
adminUserIds: []

# Max image dimension (images resized to fit)
imageMaxDimension: 768

# Max seconds between messages for same-author merge
mergeMessageGapSeconds: 120

# Max images per read_chat_images tool call
imageReadMaxPerCall: 10

# Fallback vision model for image tool results when the main model cannot read images
# imageReading:
#   fallbackEnabled: true
#   fallbackModel: moonshotai/kimi-k2.5
#   fallbackModelParams:
#     temperature: 0

# Enable automatic image captioning
imageCaptioningEnabled: false

# Emote/emoji settings
emotes:
  include: false  # Include available server emojis in LLM context

# Server members list settings
members:
  include: true  # Include server members list in context

# Prompt caching override (inherits global when omitted)
promptCaching:
  enabled: true

# Background LLM override for memory extraction (inherits effective main model when omitted)
# backgroundLlm:
#   model: google/gemini-2.5-flash
#   serviceTier: flex
#   modelParams:
#     temperature: 0.1
#   promptCaching:
#     enabled: true

# Native reply/tool loop limits (overrides global defaults)
# replyLoop:
#   maxToolCalls: 16
#   wallClockTimeoutMs: 45000
#   llmOutputTimeoutMs: 12000 # on timeout the request fails fast

# Channel dispatcher (overrides global defaults)
# dispatcher:
#   enabled: true
#   mentionDebounceMs: 500
#   defaultDebounceMs: 2000

# Custom attachments directory (default: {dataDir}/attachments)
# attachmentsDir: data/attachments

# Guild-specific instructions injected into LLM context.
# instructionsPath takes priority over inline instructions.
# Falls back to global defaultInstructions if neither is set.
# instructionsPath: config/guilds/my-guild-instructions.md
# instructions: "Be extra friendly in this server."

# Per-guild TTS configuration (overrides global defaults)
# tts:
#   enabled: true
#   voices:
#     normal:
#       voiceId: abc123  # Different voice for this guild
#       speed: 1.0
#       stability: 0.7
#       similarityBoost: 0.8
#       style: 0.0
#       useSpeakerBoost: false
#       # seed: 1
#       applyTextNormalization: "on"
#       outputFormat: mp3_44100_128
#       model: eleven_v3
#     # whisper is obsolete and ignored. Use Eleven v3 tags like [whispers] inside <voice>...</voice>.

# Bash tool toggle (global-only settings; guild can only enable/disable)
# Requires global bashTool.enabled: true and bash-vm service running.
# bashTool:
#   enabled: true
