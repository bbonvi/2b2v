# Main bot configuration — config/config.yaml
# All fields are optional. Missing values use hardcoded defaults.

# LLM backend. "openrouter" uses OPENROUTER_API_KEY; "openai-codex" uses CODEX_AUTH_PATH.
llmProvider: openrouter

# LLM model for the selected provider.
# OpenAI Codex example: gpt-5.5 (actual access depends on your ChatGPT account)
model: moonshotai/kimi-k2.5

# Model parameters passed to the selected provider (guild configs can override)
# modelParams:
#   reasoning:
#     effort: "medium"  # OpenRouter-specific override

# Thinking/reasoning level for the model (optional)
# When omitted, no thinking/reasoning is requested from the model.
# Maps to Codex reasoningEffort or OpenRouter reasoning.effort unless modelParams overrides it.
# Valid values: "minimal" | "low" | "medium" | "high" | "xhigh"
# thinkingLevel: medium

# Codex transport. Applies only when provider is openai-codex.
# Valid values: "websocket-cached" | "websocket" | "sse" | "auto"
codexTransport: websocket-cached

# Default timezone for guilds that don't override.
# All agent-facing timestamps use local wall-clock time in this timezone.
timezone: UTC

# Context window trimming thresholds
trim:
  trimTrigger: 200       # Start trimming when history exceeds this many messages
  trimTarget: 150        # Trim down to this many messages
  windowSize: 20         # Recent messages kept uncached (newer slice)
  messageCharLimit: 200  # Max chars per message before truncation
  replyQuoteChars: 50    # Max chars for reply quote excerpts

# Background memory extraction
memoryExtraction:
  postReply: true         # Run a silent memory pass after visible bot replies
  ambient:
    enabled: false        # Also review non-triggered chatter periodically
    everyMessages: 300    # Human messages since the last successful memory pass
    maxBatchMessages: 300 # Max chronological messages reviewed per ambient pass
    minIntervalSeconds: 600 # Minimum seconds between ambient passes per channel

# Ambient attention can create delayed reply candidates outside direct triggers.
ambientAttention:
  enabled: false
  evaluator:
    provider: openai-codex # or openrouter; default uses Codex spark
    model: gpt-5.3-codex-spark
    thinkingLevel: minimal
    llmOutputTimeoutMs: 8000
    modelParams:
      textVerbosity: low
  historyLimit: 40
  busyWindowMs: 60000
  busyMessageLimit: 8
  staleAfterMs: 180000
  maxNewMessagesBeforeDrop: 4
  ambientPickup:
    enabled: false
    minDelayMs: 8000
    maxDelayMs: 25000
    probabilityThreshold: 0.8
    confidenceThreshold: 0.6
    cooldownMs: 180000
    typingActiveMs: 8000
    maxRepliesPerUserPerHour: 4
    maxRepliesPerChannelPerHour: 8
    randomJitter: 0.04
    defaultReply: false
    minQuietMs: 12000
  lingering:
    enabled: true
    minDelayMs: 1500
    maxDelayMs: 7000
    probabilityThreshold: 0.58
    confidenceThreshold: 0.45
    cooldownMs: 0
    randomJitter: 0.04
    defaultReply: true
    strongWindowMs: 45000
    weakWindowMs: 180000
    typingActiveMs: 1000
    typingExtensionMs: 30000
    maxTypingExtensions: 4
    maxRepliesPerUserPerHour: 24
    maxRepliesPerChannelPerHour: 48
  followUp:
    enabled: false
    minDelayMs: 12000
    maxDelayMs: 45000
    probabilityThreshold: 0.88
    confidenceThreshold: 0.7
    cooldownMs: 300000
    typingActiveMs: 8000
    maxRepliesPerUserPerHour: 2
    maxRepliesPerChannelPerHour: 4
    randomJitter: 0.03
    defaultReply: false
    silenceMs: 12000
    maxPerExchange: 1

# Ambient initiative can proactively speak in the main channel when room/context creates an opening.
ambientInitiative:
  enabled: false
  shadowMode: false
  mainChannelId: ""       # Empty uses most active human channel over mainChannelLookbackDays
  checkIntervalMinMs: 720000
  checkIntervalMaxMs: 2700000
  activeHours:
    start: "10:00"
    end: "01:00"
  historyLimit: 60
  recentActivityMinMs: 300000
  recentActivityMaxMs: 10800000
  quietWindowMs: 360000
  typingActiveMs: 10000
  botCooldownMs: 2700000
  fatigueAfterAnyMs: 3600000
  maxPerDay: 5
  minMainChannelHumanMessages: 20
  mainChannelLookbackDays: 7
  evaluator:
    provider: openai-codex
    model: gpt-5.3-codex-spark
    thinkingLevel: minimal
    llmOutputTimeoutMs: 8000
    modelParams:
      textVerbosity: low
  selfExpression:
    enabled: true
    basePressure: 0.18
    pressureThreshold: 0.72
    probabilityThreshold: 0.72
    confidenceThreshold: 0.6
    cooldownMs: 10800000
    maxPerDay: 3
  targetedCheckin:
    enabled: true
    basePressure: 0.16
    pressureThreshold: 0.72
    probabilityThreshold: 0.72
    confidenceThreshold: 0.6
    cooldownMs: 7200000
    maxPerDay: 3
    maxPerUserPerDay: 1
    openLoopMaxAgeMs: 172800000

# Default trigger settings (guilds can override)
triggers:
  mention: true          # Respond when @mentioned
  keywords: []           # Keywords that trigger a response
  randomChance: 0        # 0–1 probability of responding to any message
  keywordDebounceMs: 2500 # Wait after a keyword or typing-aware mention trigger before replying
  typingIdleMs: 10000    # Treat typingStart from the triggering user as active for this long
  typingMaxWaitMs: 15000 # Hard cap for typing-aware keyword/mention waits

# Trigger-specific instructions injected when bot responds to each trigger type.
# Provides behavioral context for how the bot should behave in each scenario.
# triggerInstructions:
#   mention: "User directly mentioned you. Respond helpfully."
#   keyword: "Triggered by keyword match. Keep response relevant."
#   random: "You're replying unprompted. Make a brief remark without hijacking conversation."
#   scheduled: "This is a scheduled task. Follow the task instructions closely."
#   ambient_pickup: "2B noticed quiet unaddressed chatter. Normal channel message by default."
#   lingering_attention: "2B is still lightly attentive after a recent exchange."
#   follow_up: "Only add a follow-up after silence when there is a concrete natural intent."
#   ambient_initiative: "Proactive initiative; silence is valid if it feels forced."

# Max canonical stored image dimension (larger user images resized to fit)
imageMaxDimension: 4096

# Max seconds between messages to merge consecutive same-author messages
mergeMessageGapSeconds: 120

# Max images the LLM can read in a single read_chat_images call
imageReadMaxPerCall: 10

# Codex image generation request settings.
imageGeneration:
  quality: auto  # "auto" | "low" | "medium" | "high"

# Fallback vision model for image tool results when the main model cannot read images.
imageReading:
  fallbackEnabled: false
  # fallbackProvider: openrouter # or openai-codex
  fallbackModel: moonshotai/kimi-k2.5
  # fallbackModelParams:
  #   temperature: 0

# Enable automatic image captioning (requires captioning model)
imageCaptioningEnabled: false

# Emote/emoji settings
emotes:
  include: false  # Include available server emojis in LLM context (default: false)

# Server members list in LLM context
members:
  include: true  # Include server members list in context (default: true)

# Channel dispatcher — debounce and serialize per-channel message handling.
# Prevents duplicate responses when multiple messages arrive during processing.
dispatcher:
  enabled: true             # Enable per-channel dispatch (default: true)
  mentionDebounceMs: 500    # Debounce ms for mentions when typing-aware waits are disabled (default: 500)
  defaultDebounceMs: 2000   # Debounce ms for non-mention triggers (default: 2000)

# Human-paced typing indicator simulation. Agent work starts before delayed typing appears.
typingSimulation:
  enabled: false
  inputReadingWpm: 450     # Reading speed for hidden delay before typing appears
  inputMinDelayMs: 300
  inputMaxDelayMs: 3500
  outputTypingWpm: 180     # Typing speed for visible hold before each message
  outputMinHoldMs: 700
  outputMaxHoldMs: 3500

# Async agent jobs — generic runtime, currently used for image generation.
agentJobs:
  imageTimeoutMs: 300000       # Cancel image jobs after this many ms (default: 300000)
  imageCancelGraceMs: 60000    # Allow replacement cancellations only while this young (default: 60000)
  terminalVisibleMs: 600000    # Keep failed/cancelled/timed-out/sent jobs in prompt context this long (default: 600000)
  maxImageReplacements: 2      # Max replacement cancellations per original image request (default: 2)

# Prompt caching control.
# OpenRouter uses cache_control breakpoints; Codex uses split stable input messages/session routing.
promptCaching:
  enabled: true

# Prompt transport controls where logical prompt sections land. Defaults shown here
# are cache-friendly: stable sections first, volatile/current turn last.
# Roles: system | developer | user. Targets: input | instructions (Codex only).
# promptTransport:
#   openaiCodex:
#     mode: split-input # split-input | legacy-instructions
#     sections:
#       system:        { role: developer, target: instructions, cacheGroup: core }
#       core:          { role: developer, target: input, cacheGroup: core }
#       skills:        { role: developer, target: input, cacheGroup: runtime }
#       runtime:       { role: developer, target: input, cacheGroup: runtime }
#       stableContext: { role: user,      target: input, cacheGroup: stable-context }
#       olderHistory:  { role: user,      target: input, cacheGroup: older-history }
#       serverMembers:     { role: user,  target: input }
#       threadsInChannel:  { role: user,  target: input }
#       discordContext:   { role: user,   target: input }
#       upcomingSchedules: { role: user,  target: input }
#       memories:         { role: user,   target: input }
#       recentHistory:    { role: user,   target: input }
#       currentContext:   { role: user,   target: input }
#       responseInstruction: { role: developer, target: input }
#       currentTurn:     { role: user,    target: input }
#       finalActionInstruction: { role: user, target: input }
#   openrouter:
#     sections:
#       system:        { role: developer, target: input, cacheGroup: core }
#       core:          { role: developer, target: input, cacheGroup: core }
#       skills:        { role: developer, target: input, cacheGroup: runtime }
#       runtime:       { role: developer, target: input, cacheGroup: runtime }
#       stableContext: { role: user,      target: input, cacheGroup: stable-context }
#       olderHistory:  { role: user,      target: input, cacheGroup: older-history }
#       serverMembers:     { role: user,  target: input }
#       threadsInChannel:  { role: user,  target: input }
#       discordContext:   { role: user,   target: input }
#       upcomingSchedules: { role: user,  target: input }
#       memories:         { role: user,   target: input }
#       recentHistory:    { role: user,   target: input }
#       currentContext:   { role: user,   target: input }
#       responseInstruction: { role: developer, target: input }
#       currentTurn:     { role: user,    target: input }
#       finalActionInstruction: { role: user, target: input }

# Background LLM defaults for memory extraction. Omitted fields inherit the main
# effective model config. serviceTier is optional; omit it to send no service_tier.
# backgroundLlm:
#   provider: openrouter # or openai-codex; omitted inherits the main provider
#   model: google/gemini-2.5-flash
#   serviceTier: flex  # "flex" | "priority"; only supported by some providers
#   thinkingLevel: low
#   modelParams:
#     temperature: 0.1
#   promptCaching:
#     enabled: true

# Native reply/tool loop runtime limits
replyLoop:
  maxToolCalls: 64           # Hard cap on tool calls in one response run
  wallClockTimeoutMs: 240000 # Stop tool gathering and force a final no-tools reply after this many milliseconds
  llmOutputTimeoutMs: 60000  # Timeout for a single LLM turn (milliseconds); retried up to 3 total attempts

# ElevenLabs text-to-speech configuration (requires ELEVENLABS_API_KEY env var)
# When enabled, the bot can send voice messages as audio attachments
tts:
  enabled: true
  voices:
    normal:
      voiceId: WAhoMTNdLdMoq1j3wf3I  # Your ElevenLabs voice ID
      speed: 1.1
      stability: 0.80
      similarityBoost: 0.75
      style: 0.0
      useSpeakerBoost: false
      # seed: 1  # Optional best-effort consistency hint
      applyTextNormalization: "on"
      outputFormat: mp3_44100_128
      model: eleven_v3
    # whisper is obsolete and ignored. Use Eleven v3 tags like [whispers] inside <voice>...</voice>.
    # whisper:
    #   voiceId: sH0WdfE5fsKuM2otdQZr
    #   speed: 1.05
    #   stability: 0.5
    #   similarityBoost: 0.4
    #   style: 0.0
    #   useSpeakerBoost: false
    #   model: eleven_v3

# Log level: debug | info | warn | error
logLevel: info

# Directory for SQLite database and attachments
dataDir: data

# Directory for caching embedding model files
modelCacheDir: model-cache

# Qdrant vector database URL (env var QDRANT_URL takes priority)
qdrantUrl: http://localhost:6333

# UI language for VPN panel ("en" or "ru")
uiLang: en

# VPN configuration (WireGuard profile management)
# Set enabled: true to enable /vpn command
vpn:
  enabled: false
  apiUrl: ""      # Required when enabled (e.g., https://your-vpn-api.example.com)
  vpnPeer: ""     # Required when enabled (WireGuard endpoint host)
