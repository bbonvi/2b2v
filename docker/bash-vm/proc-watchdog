#!/bin/bash
# Process watchdog - detects and kills runaway user processes
# Runs as root, inaccessible to sandbox user
# Checks every 500ms; if user process count exceeds threshold, nukes all

set -euo pipefail

THRESHOLD="${PROC_WATCHDOG_THRESHOLD:-50}"
INTERVAL="${PROC_WATCHDOG_INTERVAL:-0.5}"
TARGET_USER="user"

echo "proc-watchdog: started (threshold=$THRESHOLD, interval=${INTERVAL}s)"

while true; do
  count=$(pgrep -cu "$TARGET_USER" 2>/dev/null) || count=0
  if [ "$count" -gt "$THRESHOLD" ]; then
    echo "proc-watchdog: $count processes exceeds threshold $THRESHOLD — killing all $TARGET_USER processes"
    pkill -KILL -u "$TARGET_USER" 2>/dev/null || true
  fi
  sleep "$INTERVAL"
done
