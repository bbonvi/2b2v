# Per-guild configuration — profiles/2b/guilds/{guildId}-{slug}.yaml
# All fields are optional. Missing values inherit from profiles/2b/config.yaml defaults.
# Note: uiLang and vpn settings are global-only (set in the profile config).

# Trigger settings — when should the bot respond?
triggers:
  mention: true            # Respond when @mentioned
  keywords: [2b, yorha]   # Keywords that trigger a response
  randomChance: 0.02       # 0–1 probability of responding to any message
  keywordDebounceMs: 2500  # Wait after a keyword or typing-aware mention trigger before replying
  typingIdleMs: 10000      # Treat typingStart from the triggering user as active for this long
  typingMaxWaitMs: 15000   # Hard cap for typing-aware keyword/mention waits

# Named execution policy from the profile-level modelProfiles catalog.
modelProfile: main

# Guild timezone — used for all agent-facing timestamps, scheduling, and date stamps.
# One-off schedules always use this timezone. Cron schedules default to it unless overridden.
timezone: UTC

# Context window trimming thresholds
trim:
  trimTrigger: 200
  trimTarget: 150
  windowSize: 20
  messageCharLimit: 200
  replyQuoteChars: 50

# Optional per-guild memory extraction override
# memoryExtraction:
#   modelProfile: main
#   postReply: true
#   maxToolCalls: 5
#   ambient:
#     enabled: false
#     everyMessages: 300
#     maxBatchMessages: 300
#     minIntervalSeconds: 600

# Optional per-guild relationships override
# relationships:
#   modelProfile: main
#   promptInjection: true
#   maxAxisDeltaPerSignal: 4
#   maxToolCalls: 5

# Optional per-guild ambient attention override
# ambientAttention:
#   enabled: false
#   ambientPickup:
#     enabled: false
#   lingering:
#     enabled: true
#   followUp:
#     enabled: false

# Optional known bot contacts available to the actor during ordinary initiative.
# ambientInitiative:
#   botContactIds: ["000000000000000000"]

# Discord user IDs with admin access to bot commands
adminUserIds: []

# Max seconds between messages for same-author merge
mergeMessageGapSeconds: 120

# Max ordered references per image-generation request
imageReferenceMaxPerCall: 10

# Codex image generation request settings
# imageGeneration:
#   quality: auto # "auto" | "low" | "medium" | "high"
#   modelProfile: main

# Fallback vision model for image tool results when the main model cannot read images
# imageReading:
#   fallbackEnabled: true
#   fallbackModelProfile: vision

# Emote/emoji settings
emotes:
  include: false  # Include available server emojis in LLM context

# Server members list settings
members:
  include: true  # Include server members list in context

# Prompt transport override (inherits global when omitted). Use sparingly for
# provider-role experiments; default currentTurn role is user.
# promptTransport:
#   openaiCodex:
#     sections:
#       currentTurn:
#         role: developer
#       system:
#         target: instructions
#       core:
#         target: instructions

# Native reply/tool loop limits (overrides global defaults)
# replyLoop:
#   maxToolCalls: 64
#   wallClockTimeoutMs: 240000
#   llmOutputTimeoutMs: 60000 # retried up to 3 total attempts

# Channel dispatcher (overrides global defaults)
# dispatcher:
#   enabled: true
#   mentionDebounceMs: 500 # Used for mentions when typing-aware waits are disabled
#   defaultDebounceMs: 2000

# Typing simulation override. Agent work starts before delayed typing appears.
# typingSimulation:
#   enabled: false
#   inputReadingWpm: 450
#   inputMinDelayMs: 300
#   inputMaxDelayMs: 3500
#   outputTypingWpm: 180
#   outputMinHoldMs: 700
#   outputMaxHoldMs: 3500

# Async agent job overrides (currently image generation)
# agentJobs:
#   imageTimeoutMs: 300000
#   imageCancelGraceMs: 60000
#   terminalVisibleMs: 600000
#   maxImageReplacements: 2


# Guild-specific instructions injected into LLM context.
# instructionsPath takes priority over inline instructions.
# instructionsPath: profiles/2b/guilds/my-guild-instructions.md
# instructions: "Be extra friendly in this server."

# Per-guild TTS configuration (overrides global defaults)
# tts:
#   enabled: true
#   voices:
#     normal:
#       voiceId: abc123  # Different voice for this guild
#       speed: 1.0
#       stability: 0.7
#       similarityBoost: 0.8
#       style: 0.0
#       useSpeakerBoost: false
#       # seed: 1
#       applyTextNormalization: "on"
#       outputFormat: mp3_44100_128
#       model: eleven_v3
#     # whisper is obsolete and ignored. Use Eleven v3 tags like [whispers] inside <voice>...</voice>.
