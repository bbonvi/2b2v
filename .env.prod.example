DISCORD_TOKEN=your_production_discord_bot_token
OPENROUTER_API_KEY=your_openrouter_api_key
BRAVE_API_KEY=your_brave_search_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key

LOG_LEVEL=info
DASHBOARD_PORT=31456
DASHBOARD_PASSWORD=your_dashboard_password
DASHBOARD_PASSWORDLESS_CIDRS=10.16.0.0/16
DASHBOARD_TRUSTED_PROXY_CIDRS=127.0.0.1/32

# Production config/prompt files live outside the dev checkout by default.
# The production container bind-mounts these read-only and the app watches them.
# Defaults:
# APP_CONFIG_DIR=${HOME}/.local/share/2b2v/config
# APP_PROMPTS_DIR=${HOME}/.local/share/2b2v/prompts

VPN_API_URL=
VPN_PEER=
