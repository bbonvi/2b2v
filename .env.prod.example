DISCORD_TOKEN=your_production_discord_bot_token
OPENROUTER_API_KEY=your_openrouter_api_key
# Optional: ChatGPT/Codex subscription OAuth file for llmProvider: openai-codex
CODEX_AUTH_PATH=/app/data/codex-auth.json
BRAVE_API_KEY=your_brave_search_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key

LOG_LEVEL=info
DASHBOARD_PORT=31456
DASHBOARD_PASSWORD=your_dashboard_password
DASHBOARD_PASSWORDLESS_CIDRS=10.16.0.0/16
DASHBOARD_TRUSTED_PROXY_CIDRS=127.0.0.1/32

# Production bind-mounts ./config and ./prompts read-only as the single source of truth.
# The app watches those mounted files and hot-reloads edits once running with this compose file.

VPN_API_URL=
VPN_PEER=
